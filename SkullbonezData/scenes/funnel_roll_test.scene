# funnel_roll_test.scene
# Single-ball terrain test: shallow-incidence shot that spirals around
# the water basin like a marble in a funnel.

physics on
text on
frames 900
time_scale 1.0
debug_vectors on
physics_log Debug/funnel_physics_log.csv
roll_log Debug/funnel_roll_log.txt

# Top-down tracking camera (same style as slope_roll_test.scene)
camera top 900 740 600  900 110 600  0 0 -1
track_height 540

# Normal terrain (no flat_slope override)
# Ball starts above terrain on the outer slope and is launched mostly
# tangentially with a small inward component to induce circling descent.
ball marble 900 90 600  12.0 50.0 28.8 0.25  -650 0 1500  0 0 0
