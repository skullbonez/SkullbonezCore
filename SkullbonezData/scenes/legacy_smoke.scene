# Legacy smoke test — 300 random balls with fixed seed
# Exercises the same code paths as legacy mode but deterministic
# Physics off ensures pixel-identical output across runs
seed 42
physics off
text off
frames 2
test_gl_reset
screenshot Debug/legacy_smoke.bmp frame 1

# Use the same 3 camera positions as legacy mode
camera game_model_1  321 110 557  581 40 633  0 1 0
camera game_model_2  730 100 380  709 92 482  0 1 0
camera free          900 110 900  313 31 282  0 1 0

# Generate 300 random balls (same as legacy mode)
legacy_balls 300
