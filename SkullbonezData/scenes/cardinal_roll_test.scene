# cardinal_roll_test.scene
# 4 balls at cardinal directions around the central water area.
# Each dropped from ~1m above terrain with initial sideways spin.
# Verifies rolling alignment corrects the spin on ground contact.

physics on
text on
frames unlimited
debug_vectors on
time_scale 0.1
physics_log Profile/physics_log.csv

# Top-down camera looking straight down at the scene centre
# Up vector (0,0,-1): north (lower Z) points up on screen
camera cardinal 500 800 500  500 0 500  0 0 -1

# Force at offset from COM creates torque. force=(500,0,0) at offset=(0,0,10)
# gives torque.y = 5000, creating strong Y-axis spin (wrong axis for rolling).

# North ball: rolls south, starts with strong Y-spin
ball north 500 90 350  10.0 50.0 20.0 0.3  500 0 0  0 0 10

# South ball: rolls north, starts with strong Y-spin
ball south 500 90 650  10.0 50.0 20.0 0.3  500 0 0  0 0 10

# East ball: rolls west, starts with strong Y-spin
ball east 650 90 500  10.0 50.0 20.0 0.3  500 0 0  0 0 10

# West ball: rolls east, starts with strong Y-spin
ball west 350 90 500  10.0 50.0 20.0 0.3  500 0 0  0 0 10
