# text_test.scene
# Same as water_ball_test but with text overlay enabled.
# Used to visually verify text rendering quality (UV bleeding, character shapes).

physics off
text on
frames 1
screenshot Profile/text_test.bmp frame 1

camera main 500 60 650  600 33 600  0 1 0

ball water_test 600 33 600  12.0 50.0 10.0 0.8
